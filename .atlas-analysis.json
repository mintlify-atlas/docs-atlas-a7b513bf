  "keyFeatures": [
    "Inpainting and outpainting with generative fill using selections",
    "Live Painting mode for real-time AI canvas interpretation",
    "ControlNet support: Scribble, Line art, Canny, Depth, Pose, Segmentation",
    "IP-Adapter for reference images, style transfer, and face swap",
    "Region-based generation with per-layer text prompts",
    "Upscaling to 4K/8K with tiled diffusion",
    "Custom ComfyUI workflow integration",
    "Supports Flux, Stable Diffusion 1.5, XL, and Illustrious models",
    "Local managed server or cloud generation options",
    "Job queue with history and preview of previous generations"
  ],
  "publicApiSurface": [
